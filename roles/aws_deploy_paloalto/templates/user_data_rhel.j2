#!/bin/bash
# enable password authentication
#sed 's/PasswordAuthentication no/PasswordAuthentication yes/' -i /etc/ssh/sshd_config
sed 's/PasswordAuthentication no/PasswordAuthentication yes/' -i /etc/ssh/sshd_config.d/50-cloud-init.conf
systemctl restart sshd
# set username password
echo "{{ ec2_rhel_pass }}" | passwd --stdin {{ ec2_rhel_user }}
# set default gateway
ec2_rhel_private_ip_address=$(ip addr list eth1 | awk '/inet / {print $2}' | cut -d/ -f1)
sudo nmcli connection modify "System eth1" ipv4.addresses "$ec2_rhel_private_ip_address/24" ipv4.gateway "{{ ec2_paloalto_eni1_ipaddress }}" ipv4.dns "8.8.8.8 8.8.4.4" ipv4.method "manual"
sudo nmcli connection up "System eth1"
